# Seed values setup.sh uses to pre-select the module checklist for this host.
# cloud stays off by default on the Duo: the interim Ubuntu partition is ~50 GB
# (see docs/INSTALL-LOG.md) and the cloud module pulls multi-GB closures.
MODULE_PYTHON=false
MODULE_NODE=false
MODULE_JAVA=false
MODULE_AI=true
MODULE_CLOUD=false
