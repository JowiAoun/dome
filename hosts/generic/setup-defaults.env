# Seed values setup.sh uses to pre-select the module checklist for this host.
# The user can still toggle everything interactively; saved choices in
# user-config.nix always win over these seeds on re-runs.
MODULE_PYTHON=false
MODULE_NODE=false
MODULE_JAVA=false
MODULE_AI=true
MODULE_CLOUD=true
# Desktop apps stay off for "generic": it also covers WSL and headless boxes,
# where a browser and Discord are ~1.5 GB of closure nobody can launch.
MODULE_APPS=false
