# Reference template — see duo-watch-displays.service for usage.
[Unit]
Description=zenduo: sync bottom panel backlight to the top panel
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.dotfiles/duo/bin/duo watch-backlight
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
